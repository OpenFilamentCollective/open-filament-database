# Normalize all text files to LF line endings
* text=auto eol=lf

# Windows batch files use CRLF
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.sqlite binary
*.sqlite3 binary
*.db binary
*.gz binary
*.xz binary
*.zip binary
*.tar binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
