{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openfilamentdatabase.org/schemas/change-set.schema.json",
  "title": "ChangeSet",
  "description": "Top-level structure for storing all pending changes in localStorage (key: 'ofd_pending_changes')",
  "type": "object",
  "required": ["changes", "images", "lastModified"],
  "properties": {
    "changes": {
      "type": "object",
      "description": "Map of entity path to its change record",
      "additionalProperties": {
        "$ref": "entity-change.schema.json"
      },
      "patternProperties": {
        "^[a-z0-9_/-]+$": {
          "$ref": "entity-change.schema.json"
        }
      }
    },
    "images": {
      "type": "object",
      "description": "Map of image ID to its metadata reference",
      "additionalProperties": {
        "$ref": "image-reference.schema.json"
      },
      "patternProperties": {
        "^img_[a-zA-Z0-9_-]+$": {
          "$ref": "image-reference.schema.json"
        }
      }
    },
    "lastModified": {
      "type": "integer",
      "description": "Unix timestamp (milliseconds) of the last modification to the change set",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "changes": {
        "brands/prusament/materials/pla/filaments/pla_galaxy_black": {
          "entity": {
            "type": "filament",
            "path": "brands/prusament/materials/pla/filaments/pla_galaxy_black",
            "id": "pla_galaxy_black"
          },
          "operation": "create",
          "data": {
            "name": "PLA Galaxy Black",
            "color": "#000000"
          },
          "timestamp": 1706745600000,
          "description": "Created filament PLA Galaxy Black"
        }
      },
      "images": {
        "img_abc123": {
          "id": "img_abc123",
          "entityPath": "brands/prusament",
          "property": "logo",
          "filename": "prusament-logo.png",
          "mimeType": "image/png",
          "storageKey": "ofd_image_img_abc123"
        }
      },
      "lastModified": 1706745600000
    }
  ]
}
