{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openfilamentdatabase.org/schemas/property-change.schema.json",
  "title": "PropertyChange",
  "description": "Records a single property-level change within an entity",
  "type": "object",
  "required": ["property", "timestamp"],
  "properties": {
    "property": {
      "type": "string",
      "description": "Property path using dot notation (e.g., 'ships_from.0', 'settings.temp')",
      "minLength": 1
    },
    "oldValue": {
      "description": "Previous value of the property (undefined for new properties)",
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "object" },
        { "type": "array" }
      ]
    },
    "newValue": {
      "description": "New value of the property (undefined for deleted properties)",
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        { "type": "object" },
        { "type": "array" }
      ]
    },
    "timestamp": {
      "type": "integer",
      "description": "Unix timestamp (milliseconds) when this property was changed",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "property": "ships_from.0",
      "oldValue": "US",
      "newValue": "EU",
      "timestamp": 1706745600000
    },
    {
      "property": "settings.temp",
      "newValue": 220,
      "timestamp": 1706745600000
    }
  ]
}
