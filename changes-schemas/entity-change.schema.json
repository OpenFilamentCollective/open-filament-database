{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openfilamentdatabase.org/schemas/entity-change.schema.json",
  "title": "EntityChange",
  "description": "Records a single change operation (create, update, or delete) on an entity",
  "type": "object",
  "required": ["entity", "operation", "timestamp", "description"],
  "properties": {
    "entity": {
      "$ref": "entity-identifier.schema.json",
      "description": "Identifies which entity was changed"
    },
    "operation": {
      "type": "string",
      "enum": ["create", "update", "delete"],
      "description": "The type of operation performed"
    },
    "data": {
      "type": "object",
      "description": "For create/update operations: the modified entity data"
    },
    "originalData": {
      "type": "object",
      "description": "For update operations: the original entity data before changes"
    },
    "propertyChanges": {
      "type": "array",
      "description": "Detailed list of property-level changes",
      "items": {
        "$ref": "property-change.schema.json"
      }
    },
    "timestamp": {
      "type": "integer",
      "description": "Unix timestamp (milliseconds) when this change was made",
      "minimum": 0
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the change",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "operation": { "const": "create" } }
      },
      "then": {
        "required": ["data"]
      }
    },
    {
      "if": {
        "properties": { "operation": { "const": "update" } }
      },
      "then": {
        "required": ["data", "originalData"]
      }
    }
  ],
  "examples": [
    {
      "entity": {
        "type": "filament",
        "path": "brands/prusament/materials/pla/filaments/pla_galaxy_black",
        "id": "pla_galaxy_black"
      },
      "operation": "create",
      "data": {
        "name": "PLA Galaxy Black",
        "color": "#000000"
      },
      "timestamp": 1706745600000,
      "description": "Created filament PLA Galaxy Black"
    },
    {
      "entity": {
        "type": "filament",
        "path": "brands/prusament/materials/pla/filaments/pla_basic",
        "id": "pla_basic"
      },
      "operation": "update",
      "data": {
        "name": "PLA Basic",
        "color": "#FFFFFF"
      },
      "originalData": {
        "name": "PLA Basic",
        "color": "#F0F0F0"
      },
      "propertyChanges": [
        {
          "property": "color",
          "oldValue": "#F0F0F0",
          "newValue": "#FFFFFF",
          "timestamp": 1706745600000
        }
      ],
      "timestamp": 1706745600000,
      "description": "Updated filament PLA Basic"
    }
  ]
}
