{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openfilamentdatabase.org/schemas/change-export.schema.json",
  "title": "ChangeExport",
  "description": "Export format for downloading changes as JSON (includes embedded base64 images)",
  "type": "object",
  "required": ["metadata", "changes", "images"],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Metadata about the export",
      "required": ["exportedAt", "version", "changeCount", "imageCount"],
      "properties": {
        "exportedAt": {
          "type": "integer",
          "description": "Unix timestamp (milliseconds) when the export was created",
          "minimum": 0
        },
        "version": {
          "type": "string",
          "description": "Schema version for the export format",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "examples": ["1.0.0"]
        },
        "changeCount": {
          "type": "integer",
          "description": "Total number of changes included in this export",
          "minimum": 0
        },
        "imageCount": {
          "type": "integer",
          "description": "Total number of images included in this export",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "changes": {
      "type": "array",
      "description": "Array of all entity changes",
      "items": {
        "$ref": "entity-change.schema.json"
      }
    },
    "images": {
      "type": "object",
      "description": "Map of image ID to embedded image data",
      "additionalProperties": {
        "type": "object",
        "required": ["filename", "mimeType", "data"],
        "properties": {
          "filename": {
            "type": "string",
            "description": "Original filename",
            "minLength": 1
          },
          "mimeType": {
            "type": "string",
            "description": "MIME type of the image",
            "pattern": "^image/(png|jpeg|jpg|gif|webp|svg\\+xml)$"
          },
          "data": {
            "type": "string",
            "description": "Base64-encoded image data",
            "contentEncoding": "base64"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "metadata": {
        "exportedAt": 1706745600000,
        "version": "1.0.0",
        "changeCount": 2,
        "imageCount": 1
      },
      "changes": [
        {
          "entity": {
            "type": "filament",
            "path": "brands/prusament/materials/pla/filaments/pla_galaxy_black",
            "id": "pla_galaxy_black"
          },
          "operation": "create",
          "data": {
            "name": "PLA Galaxy Black",
            "color": "#000000"
          },
          "timestamp": 1706745600000,
          "description": "Created filament PLA Galaxy Black"
        }
      ],
      "images": {
        "img_abc123": {
          "filename": "prusament-logo.png",
          "mimeType": "image/png",
          "data": "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="
        }
      }
    }
  ]
}
